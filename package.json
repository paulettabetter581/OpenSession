{
  "name": "opensession",
  "version": "1.0.0",
  "description": "A web-based session viewer for AI coding tools — browse, search, and manage sessions from OpenCode, Claude Code, Codex CLI, and Gemini CLI.",
  "type": "module",
  "bin": {
    "opensession": "bin/cli.mjs",
    "oh-my-opensession": "bin/cli.mjs"
  },
  "scripts": {
    "start": "node bin/cli.mjs",
    "dev": "node bin/cli.mjs --open"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "keywords": [
    "opensession",
    "opencode",
    "claude-code",
    "codex",
    "gemini",
    "session-viewer",
    "ai-coding",
    "session-manager",
    "cli"
  ],
  "author": "HeavyBunny19C",
