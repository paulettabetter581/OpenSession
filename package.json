  "repository": {
    "type": "git",
    "url": "git+https://github.com/HeavyBunny19C/OpenSession.git"
  },
  "homepage": "https://github.com/HeavyBunny19C/OpenSession",
  "files": [
    "bin/",
    "src/"
  ]
}
